{
  "info": {
    "name": "Content Tracker API",
    "_postman_id": "content-tracker-api-v2",
    "description": "Collection para o sistema de controle de leitura/visualização de mangás, animes e novels.\n\nConfigure as variáveis:\n- `base_url`: URL base da API (ex: http://localhost:8000/api)\n- `token`: Bearer token obtido após login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login com Google",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"SEU_GOOGLE_ID_TOKEN_AQUI\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/google",
              "host": ["{{base_url}}"],
              "path": ["auth", "google"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Me (usuário autenticado)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Contents (Acervo)",
      "item": [
        {
          "name": "Listar conteúdos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/contents?type=manga&search=&page=1",
              "host": ["{{base_url}}"],
              "path": ["contents"],
              "query": [
                { "key": "type", "value": "manga", "description": "manga | anime | novel" },
                { "key": "search", "value": "" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Listar animes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/contents?type=anime",
              "host": ["{{base_url}}"],
              "path": ["contents"],
              "query": [
                { "key": "type", "value": "anime" }
              ]
            }
          }
        },
        {
          "name": "Listar novels",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/contents?type=novel",
              "host": ["{{base_url}}"],
              "path": ["contents"],
              "query": [
                { "key": "type", "value": "novel" }
              ]
            }
          }
        },
        {
          "name": "Criar conteúdo (com capa)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "One Piece", "type": "text" },
                { "key": "type", "value": "manga", "type": "text", "description": "manga | anime | novel" },
                { "key": "total_units", "value": "1110", "type": "text" },
                { "key": "cover", "type": "file", "src": "", "description": "Imagem da capa (max 2MB)" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/contents",
              "host": ["{{base_url}}"],
              "path": ["contents"]
            }
          }
        },
        {
          "name": "Criar conteúdo (sem capa)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Naruto Shippuden\",\n  \"type\": \"anime\",\n  \"total_units\": 500\n}"
            },
            "url": {
              "raw": "{{base_url}}/contents",
              "host": ["{{base_url}}"],
              "path": ["contents"]
            }
          }
        },
        {
          "name": "Buscar conteúdo por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/contents/1",
              "host": ["{{base_url}}"],
              "path": ["contents", "1"]
            }
          }
        },
        {
          "name": "Atualizar conteúdo",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "One Piece", "type": "text" },
                { "key": "total_units", "value": "1115", "type": "text" },
                { "key": "cover", "type": "file", "src": "", "description": "Nova capa (opcional)" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/contents/1",
              "host": ["{{base_url}}"],
              "path": ["contents", "1"]
            }
          }
        },
        {
          "name": "Remover conteúdo",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/contents/1",
              "host": ["{{base_url}}"],
              "path": ["contents", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Sites",
      "item": [
        {
          "name": "Listar sites",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/sites?page=1",
              "host": ["{{base_url}}"],
              "path": ["sites"],
              "query": [
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Criar site",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MangaDex\",\n  \"url\": \"https://mangadex.org\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/sites",
              "host": ["{{base_url}}"],
              "path": ["sites"]
            }
          }
        },
        {
          "name": "Buscar site por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/sites/1",
              "host": ["{{base_url}}"],
              "path": ["sites", "1"]
            }
          }
        },
        {
          "name": "Atualizar site",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MangaDex\",\n  \"url\": \"https://mangadex.org\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/sites/1",
              "host": ["{{base_url}}"],
              "path": ["sites", "1"]
            }
          }
        },
        {
          "name": "Remover site",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/sites/1",
              "host": ["{{base_url}}"],
              "path": ["sites", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "User Contents (Biblioteca)",
      "item": [
        {
          "name": "Listar biblioteca",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/user-contents?type=&status=&page=1",
              "host": ["{{base_url}}"],
              "path": ["user-contents"],
              "query": [
                { "key": "type", "value": "", "description": "manga | anime | novel" },
                { "key": "status", "value": "", "description": "reading | completed | paused | dropped | plan_to_read" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Filtrar por tipo (manga)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/user-contents?type=manga",
              "host": ["{{base_url}}"],
              "path": ["user-contents"],
              "query": [
                { "key": "type", "value": "manga" }
              ]
            }
          }
        },
        {
          "name": "Filtrar por status (reading)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/user-contents?status=reading",
              "host": ["{{base_url}}"],
              "path": ["user-contents"],
              "query": [
                { "key": "status", "value": "reading" }
              ]
            }
          }
        },
        {
          "name": "Adicionar à biblioteca",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_id\": 1,\n  \"site_id\": 1,\n  \"current_units\": 0,\n  \"status\": \"plan_to_read\",\n  \"rating\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/user-contents",
              "host": ["{{base_url}}"],
              "path": ["user-contents"]
            }
          }
        },
        {
          "name": "Buscar item por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/user-contents/1",
              "host": ["{{base_url}}"],
              "path": ["user-contents", "1"]
            }
          }
        },
        {
          "name": "Atualizar item (status/rating/progresso)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"reading\",\n  \"current_units\": 150,\n  \"rating\": 9.5,\n  \"site_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/user-contents/1",
              "host": ["{{base_url}}"],
              "path": ["user-contents", "1"]
            }
          }
        },
        {
          "name": "Incrementar +1 unidade",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/user-contents/1/increment",
              "host": ["{{base_url}}"],
              "path": ["user-contents", "1", "increment"]
            }
          }
        },
        {
          "name": "Remover da biblioteca",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/user-contents/1",
              "host": ["{{base_url}}"],
              "path": ["user-contents", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Utilitários",
      "item": [
        {
          "name": "Teste de conexão DB",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/db-test",
              "host": ["{{base_url}}"],
              "path": ["db-test"]
            }
          }
        }
      ]
    }
  ]
}
